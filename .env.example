# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://ripple:ripple@localhost:5432/ripple_studio

# Redis
REDIS_URL=redis://localhost:6379

# Sui
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# zkLogin OAuth (create apps at Google Cloud Console + Apple Developer)
NEXT_PUBLIC_ZKLOGIN_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_ZKLOGIN_APPLE_CLIENT_ID=
NEXT_PUBLIC_SUI_NETWORK=testnet

# Auth secrets (generate: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ZKLOGIN_SALT_ENCRYPTION_KEY=

# Token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Walrus (testnet defaults work out of the box)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.testnet.walrus.space
WALRUS_STORAGE_EPOCHS=26
WALRUS_UPLOAD_BATCH_SIZE=10

# Metadata (PR-7)
METADATA_UPLOAD_BATCH_SIZE=50
# Mainnet: set signer key + upload relay (no public publisher on mainnet)
WALRUS_SIGNER_PRIVATE_KEY=

# AI (PR-8 Creator Coach)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage (staging before Walrus)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000