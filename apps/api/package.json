{
  "name": "@ripple-studio/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "prisma generate && nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@mysten/sui": "^1.30.0",
    "@ripple-studio/generation": "*",
    "@ripple-studio/ai-knowledge": "*",
    "@ripple-studio/memory": "*",
    "@ripple-studio/metadata": "*",
    "openai": "^4.104.0",
    "@ripple-studio/walrus-client": "*",
    "archiver": "^7.0.1",
    "bullmq": "^5.53.2",
    "ioredis": "^5.6.1",
    "@nestjs/common": "^11.1.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.2",
    "@prisma/client": "^6.9.0",
    "@ripple-studio/shared": "*",
    "jose": "^6.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@ripple-studio/typescript-config": "*",
    "@types/archiver": "^6.0.3",
    "@types/express": "^5.0.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}